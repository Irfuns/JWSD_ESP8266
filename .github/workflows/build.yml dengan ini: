name: Build JWSD ESP8266 Firmware

on:
  push:
    branches: [ main ]
  workflow_dispatch:

jobs:
  build:
    runs-on: ubuntu-latest

    steps:
    - name: Checkout source
      uses: actions/checkout@v4

    - name: Setup Arduino CLI
      uses: arduino/setup-arduino-cli@v1

    - name: Configure ESP8266 board URL
      run: |
        arduino-cli config init
        arduino-cli config set board_manager.additional_urls https://arduino.esp8266.com/stable/package_esp8266com_index.json

    - name: Install ESP8266 Core
      run: |
        arduino-cli core update-index
        arduino-cli core install esp8266:esp8266

    - name: Install Required Libraries
      run: |
        arduino-cli lib install "ArduinoJson"
        arduino-cli lib install "RTClib"
        arduino-cli lib install "PrayerTimes"
        arduino-cli lib install "NTPClient"

    # ✅ Install DMDESP manually (no Library Manager)
    - name: Install DMDESP manually
      run: |
        mkdir -p $HOME/Arduino/libraries
        git clone --depth 1 https://github.com/busel7/DMDESP.git $HOME/Arduino/libraries/DMDESP

    - name: Compile Firmware
      run: |
        arduino-cli compile \
          --fqbn esp8266:esp8266:generic \
          --output-dir build \
          JWSD_ESP8266

    - name: Upload Firmware BIN
      uses: actions/upload-artifact@v4
      with:
        name: JWSD_ESP8266_BIN
        path: build/*.bin
